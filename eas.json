{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote",
    "promptToConfigurePushToInstall": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "config": {
        "projectRoot": "frontend"
      }
    },
    "production": {
      "autoIncrement": true,
      "config": {
        "projectRoot": "frontend"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
